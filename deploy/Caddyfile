# Caddy auto-obtains and renews the Let's Encrypt certificate for this domain.
# HTTP -> HTTPS redirect is automatic once the cert is in place.

mrr-process-tracker.joulestowatts.com {
    encode zstd gzip

    # Vite-built hashed assets (filenames change when content changes) → cache forever.
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    # Everything else (index.html, /api/*, root-level static files) → no browser cache.
    # This guarantees users always pull the freshest index.html after a deploy, which
    # in turn references the latest hashed JS/CSS so they get the new bundle.
    @nocache not path /assets/*
    header @nocache Cache-Control "no-store"

    reverse_proxy app:8000 {
        # SSE / EventSource (used by features/notifications) needs streaming + no buffering.
        flush_interval -1
    }
}
